# Alfresco Content Lake deployment defaults.
# To override values locally, create a .env.local file and run via the Makefile
# (make up / make down / etc.) — it passes --env-file .env.local automatically.
# When using docker compose directly, pass the flag explicitly:
#   docker compose --env-file .env.local up --build

# Alfresco platform
SERVER_NAME=localhost
ALFRESCO_CE_TAG=25.3.0
SEARCH_CE_TAG=2.0.17
SHARE_TAG=25.3.0
CONTROL_CENTER_TAG=10.2.0
POSTGRES_TAG=15.6
TRANSFORM_ENGINE_TAG=5.2.4
ACTIVEMQ_TAG=5.18-jre17-rockylinux8

# Credentials
ALFRESCO_ADMIN_USER=admin
ALFRESCO_ADMIN_PASSWORD=admin
POSTGRES_USER=alfresco
POSTGRES_PASSWORD=alfresco
POSTGRES_DB=alfresco
SOLR_SECRET=3uux2z0blli
ACTIVEMQ_USER=admin
ACTIVEMQ_PASSWORD=admin
HXPR_IDP_CLIENT_ID=nuxeo-client
HXPR_IDP_CLIENT_SECRET=secret
HXPR_IDP_USERNAME=testuser
HXPR_IDP_PASSWORD=password
HXPR_REPOSITORY_ID=default
HXPR_TARGET_PATH=/alfresco-sync

# HXPR and supporting infrastructure
HXPR_LOCAL_IMAGE=alfresco-content-lake/hxpr-app:local
HXPR_GIT_URL=https://github.com/HylandSoftware/hxpr.git
HXPR_GIT_REF=feature/CIN-1509-CreateEmbeddingAPI
# Pin to a specific commit SHA for reproducible builds (leave empty to track the branch tip).
HXPR_GIT_SHA=
IDP_TAG=26.35.14
MONGODB_TAG=8.2.5
OPENSEARCH_TAG=3.5.0
OPENSEARCH_ADMIN_PASSWORD=Hyland_Pass1!
LOCALSTACK_TAG=4.13.1
MOCKOON_TAG=9.3.0
HXTS_TAG=3.0.566

# Remote source contexts built by Docker/BuildKit.
CONTENT_LAKE_GIT_CONTEXT=https://github.com/aborroy/alfresco-content-lake.git#main
CONTENT_LAKE_UI_GIT_CONTEXT=https://github.com/aborroy/alfresco-content-lake-ui.git#main
ACA_TAG=7.2.0

# HXPR build credentials are intentionally not stored here.
# Export these before running docker compose:
#   MAVEN_USERNAME
#   MAVEN_PASSWORD
#   NEXUS_USERNAME
#   NEXUS_PASSWORD
# Optional if the HXPR Git repository is not publicly cloneable:
#   HXPR_GIT_AUTH_TOKEN

# AI / Docker Model Runner
# Spring AI appends /v1 itself, so keep the base URL at the service root.
MODEL_RUNNER_URL=http://model-runner.docker.internal
EMBEDDING_MODEL=ai/mxbai-embed-large
LLM_MODEL=ai/gpt-oss

# Public proxy port and bind address
PUBLIC_PORT=8080
BIND_IP=0.0.0.0
